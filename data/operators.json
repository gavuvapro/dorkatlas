[
  {
    "id": "site",
    "name": "site:",
    "description": "Restricts results to a specific website or domain.",
    "syntax": "site:example.com",
    "useCases": [
      "Find content on a particular domain",
      "Search within a company website",
      "Locate pages on academic sites"
    ],
    "examples": [
      "site:github.com next.js",
      "site:arxiv.org machine learning",
      "site:nytimes.com climate change"
    ],
    "difficulty": "Beginner",
