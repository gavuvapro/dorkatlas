  {
    "id": "wildcard",
    "name": "* (Wildcard)",
    "description": "Matches any word or phrase in the position.",
    "syntax": "keyword * keyword",
    "useCases": [
      "Find variations in phrasing",
      "Locate specific sentence structures"
    ],
    "examples": [
      "\"how to * next.js\"",
      "climate * change",
      "\"the future of * technology\""
    ],
    "difficulty": "Intermediate",
    "professionTags": ["Writers", "Researchers", "SEO Specialists"],
    "intentTags": ["Research", "Inspiration"],
    "category": "Education",
    "isAdvanced": false
  },
  {
    "id": "parentheses",
    "name": "() (Grouping)",
    "description": "Groups terms for complex logical queries.",
    "syntax": "(term1 OR term2) term3",
    "useCases": [
      "Build complex search logic",
      "Combine multiple operators",
      "Create precise nested queries"
    ],
    "examples": [
      "(typescript OR javascript) tutorial",
      "(climate OR environment) policy filetype:pdf",
      "(\"machine learning\" OR AI) ethics"
    ],
    "difficulty": "Advanced",
    "professionTags": ["Developers", "Researchers", "Data Analysts"],
    "intentTags": ["Research", "Academic Study"],
    "category": "Science",
    "isAdvanced": true
  },
